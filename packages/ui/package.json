{
	"name": "@melony/ui",
	"version": "0.1.15",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"scripts": {
		"dev": "npm run build -- --watch",
		"lint": "eslint . --max-warnings 0",
