		"eslint": "^8.57.0",
		"react": "^18.2.0",
		"tailwindcss": "^3.4.1",
		"tsup": "8.0.2",
		"typescript": "^5.3.3"
	},
	"dependencies": {
		"@hookform/resolvers": "^3.3.4",
		"@melony/types": "workspace:*",
